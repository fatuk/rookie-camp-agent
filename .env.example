# Токен бота от @BotFather в Telegram
BOT_TOKEN=

# Ключ Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Кодовое слово, которое ты раздаёшь ученикам
ACCESS_CODE=

# --- Необязательные настройки ---

# Модель Gemini для чата (по умолчанию gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Модель для генерации картинок (по умолчанию gemini-3.1-flash-image)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Сообщений в день на одного ученика (по умолчанию 50)
# DAILY_LIMIT=50

# Твой Telegram user id — доступ к /stats и без лимита (узнать: @userinfobot)
# ADMIN_ID=

# Публичный URL для вебхука. На Render НЕ нужен — там есть RENDER_EXTERNAL_URL.
# Локально не задавай — бот сам перейдёт в режим polling.
# WEBHOOK_URL=
